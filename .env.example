# Covert — environment variables
# Copy to .env.local for local dev; set the same keys in Vercel project settings.

# --- PCR extraction (Phase 1, live now) ---
# Anthropic API key for the Claude PDF-vision pass. Without it, parsing still
# runs the free text pass and flags the chart/image fields for manual review.
ANTHROPIC_API_KEY=

# --- Database: Neon Postgres (Phase 2, live now) ---
# Pooled connection (app runtime) — use Neon's "-pooler" host.
DATABASE_URL=
# Direct connection (migrations). If you don't have a separate one, set it to the
# same value as DATABASE_URL.
DIRECT_URL=

# --- Auth: Clerk (Phase 3, live now) ---
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
# Route config (these match the in-app /sign-in, /sign-up, /dashboard pages)
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/dashboard
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/dashboard

# --- Email / CTA notifications: Resend (Phase 5) ---
# RESEND_API_KEY=
# CTA_NOTIFY_TO=jesse@... # who gets the "Request Client Service Agreement" alert
